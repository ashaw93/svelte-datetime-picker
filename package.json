{
  "name": "svelte-datetime-picker",
  "version": "0.0.0",
  "description": "Reusable Svelte date and date-time picker components with range and single-value modes.",
  "type": "module",
  "sideEffects": false,
  "svelte": "./src/lib/index.ts",
  "types": "./src/lib/index.ts",
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "svelte": "./src/lib/index.ts",
      "default": "./src/lib/index.ts"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "svelte",
    "datepicker",
    "datetime-picker",
    "date-range-picker",
    "time-picker"
  ],
  "files": [
    "src/lib",
    "README.md",
    "svelte.config.js"
  ],
  "scripts": {
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.8",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  }
}
