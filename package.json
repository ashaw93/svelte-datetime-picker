{
  "name": "svelte-datetime-picker",
  "version": "0.0.0",
  "description": "Reusable Svelte date and date-time picker components with range and single-value modes.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashaw93/svelte-datetime-picker.git"
  },
  "homepage": "https://github.com/ashaw93/svelte-datetime-picker",
  "bugs": {
    "url": "https://github.com/ashaw93/svelte-datetime-picker/issues"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "keywords": [
    "svelte",
    "datepicker",
    "datetime-picker",
    "date-range-picker",
    "time-picker"
  ],
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "package": "svelte-package",
    "prepare": "npm run package",
    "prepublishOnly": "npm run check && npm run test && npm run package"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.2",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  }
}
